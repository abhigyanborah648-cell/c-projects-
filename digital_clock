
#include<stdio.h>
#include<stdlib.h>
#include<time.h>
#include<unistd.h>
void fill_time(char*,int);
void fill_time(char* buffer,int format)
{
    time_t raw_time;
    struct tm* current_time;
    time(&raw_time);
    current_time=localtime(&raw_time);
    if (format==1)
    {
        strftime(buffer,50,"%H:%M:%S",current_time);
    }
    else
    {
        strftime(buffer,50,"%I:%M:%S %p",current_time);
    }
}
void fill_date(char*);
void fill_date(char* buffer)
{
    time_t raw_time;
    struct tm* current_time;
    time(&raw_time);
    current_time=localtime(&raw_time);
    strftime(buffer,100,"%A %B %d %Y",current_time);
}
int input_format()
{
    int format;
    printf("1) 24hr format\n");
    printf("2) 12 hr format\n");
    printf("choose a format:");
    scanf("%d",&format);
    return format;
}
void clear()
{
   system("cls");
}
int main()
{
    int format1=input_format();
    char time_str[50],date[100];

    while (1)
    {
        fill_time(time_str,format1);
        fill_date(date);
        clear();
        printf("DATE:%s\n",date);
        printf("TIME:%s\n",time_str);
        sleep(1);   
        
    };
    
    return 0;
}
