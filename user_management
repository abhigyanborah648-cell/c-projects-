void fix_input(char *string)
{
    int n;
    n = strcspn(string, "/n");
    string[n] = '\0';
}

void input_details(char *username, char *password)
{
    printf("enter username:");
    fgets(username, credential_length, stdin);
    fix_input(username);

    printf("enter password:");
    int i=0;
    char ch;
    while (1)
    {
        ch = _getch();
        if (ch == 13)
        {
            break;
        }
        else if (ch == 8)
        {
            if (i > 0)
            {
                i--;
                printf("\b \b");
            }
        }
        else if (i < credential_length - 1)
        {
            password[i++] = ch;
            printf("*");
        }
    }
    password[i] = '\0';
    printf("\n");
}

void register_user()
{
    if (user_count == max_users)
    {
        printf("MAX %d USERS ARE ALLOWED", max_users);
    }
    else
    {
        printf("new regristRation:\n");
        input_details(users[user_count].username, users[user_count].password);
        user_count++;
        printf("\nREGRISTRATIONN SUCCESSFUL\n");
    }
}
int login_user()
{
    char username[credential_length];
    char password[credential_length];
    input_details(username,password);
    for (int i = 0; i < user_count; i++)
    {
        if (strcmp(users[i].username, username) == 0 && strcmp(users[i].password, password) == 0)
        {
            return i;
        }
    }
    return -1;
}
